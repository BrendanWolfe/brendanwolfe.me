# Public Turnstile key used in the browser
PUBLIC_TURNSTILE_SITE_KEY=

# Server-side Turnstile settings
TURNSTILE_SECRET_KEY=
# Optional: set to your production hostname (for example: brendanwolfe.me)
TURNSTILE_EXPECTED_HOSTNAME=

# SMTP transport
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# Destination inbox
CONTACT_TO_EMAIL=
# Optional override, defaults to SMTP_USER
CONTACT_FROM_EMAIL=