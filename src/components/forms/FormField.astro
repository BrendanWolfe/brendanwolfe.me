---
interface Props {
  label: string;
  name: string;
  type?: 'text' | 'email' | 'textarea';
  autocomplete?: string;
  required?: boolean;
  minlength?: number;
  maxlength?: number;
  rows?: number;
}

const {
  label,
  name,
  type = 'text',
  autocomplete,
  required = false,
  minlength,
  maxlength,
  rows = 5
} = Astro.props;

const controlClass =
  'w-full rounded-md border border-bw-border bg-bw-surface/60 px-3 py-2 text-bw-heading outline-none transition-colors focus:border-bw-accent';
---

<label class="grid gap-1.5 text-base font-medium text-bw-heading">
  {label}
  {type === 'textarea' ? (
    <textarea
      name={name}
      rows={rows}
      required={required}
      minlength={minlength}
      maxlength={maxlength}
      class={controlClass}
    ></textarea>
  ) : (
    <input
      name={name}
      type={type}
      autocomplete={autocomplete}
      required={required}
      minlength={minlength}
      maxlength={maxlength}
      class={controlClass}
    />
  )}
</label>
