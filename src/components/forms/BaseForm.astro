---
import TurnstileWidget from './TurnstileWidget.astro';

interface Props {
  action?: string;
  actionName?: string;
  ariaLabel?: string;
  submitLabel?: string;
  turnstileAction?: string;
  withTurnstile?: boolean;
}

const {
  action = '',
  actionName,
  ariaLabel = 'Form',
  submitLabel = 'Send Message',
  turnstileAction,
  withTurnstile = true
} = Astro.props;

const normalizedActionName = (actionName ?? 'form').replace(/[^a-zA-Z0-9_-]+/g, '_').toLowerCase();
const resolvedTurnstileAction = turnstileAction ?? `${normalizedActionName}_form`;
---

<form
  aria-label={ariaLabel}
  class="w-full text-left"
  method="POST"
  action={action}
  data-base-form
  data-action-name={actionName}
>
  <div class="grid gap-3">
    <div class="absolute -left-[10000px] top-auto h-px w-px overflow-hidden" aria-hidden="true">
      <label>
        Company
        <input type="text" name="company" tabindex="-1" autocomplete="off" />
      </label>
    </div>

    <input type="hidden" name="formLoadedAt" data-form-loaded-at />

    <slot />

    {withTurnstile && (
      <TurnstileWidget action={resolvedTurnstileAction} server:defer>
        <p slot="fallback" class="text-xs text-bw-body">Loading captcha challenge...</p>
      </TurnstileWidget>
    )}

    <p data-form-status class="min-h-5 text-sm text-bw-sub" role="status" aria-live="polite"></p>

    <button
      type="submit"
      class="mt-1 w-fit rounded-md bg-bw-accent px-4 py-2 text-base font-semibold text-bw-bg transition hover:bg-bw-accent-hover disabled:cursor-not-allowed disabled:opacity-60"
      data-submit-button
    >
      {submitLabel}
    </button>
  </div>
</form>

<script>
  import { actions, isActionError, isInputError } from 'astro:actions';

  (() => {
    const forms = document.querySelectorAll<HTMLFormElement>('form[data-base-form]');

    const resolveActionClient = (path: string): ((input: FormData) => Promise<{ data?: unknown; error?: unknown }>) | null => {
      if (!path) {
        return null;
      }

      let current: unknown = actions;
      for (const segment of path.split('.')) {
        if (!current || typeof current !== 'object' || !(segment in current)) {
          return null;
        }

        current = (current as Record<string, unknown>)[segment];
      }

      return typeof current === 'function'
        ? (current as (input: FormData) => Promise<{ data?: unknown; error?: unknown }>)
        : null;
    };

    const trackUmamiEvent = (eventName: string, eventData: Record<string, string>) => {
      if (window.umami && typeof window.umami.track === 'function') {
        window.umami.track(eventName, eventData);
      }
    };

    const setLoadedAt = (form: HTMLFormElement) => {
      const loadedAtInput = form.querySelector<HTMLInputElement>('[data-form-loaded-at]');
      if (loadedAtInput && !loadedAtInput.value) {
        loadedAtInput.value = String(Date.now());
      }
    };

    const setStatus = (statusEl: HTMLElement, message: string, state: 'idle' | 'error' | 'success') => {
      statusEl.textContent = message;
      statusEl.classList.remove('text-bw-sub', 'text-red-300', 'text-green-300');

      if (state === 'error') {
        statusEl.classList.add('text-red-300');
        return;
      }

      if (state === 'success') {
        statusEl.classList.add('text-green-300');
        return;
      }

      statusEl.classList.add('text-bw-sub');
    };

    for (const form of forms) {
      if (form.dataset.formReady === 'true') {
        continue;
      }

      form.dataset.formReady = 'true';
      setLoadedAt(form);

      form.addEventListener('submit', async (event: SubmitEvent) => {
        event.preventDefault();

        const statusEl = form.querySelector<HTMLElement>('[data-form-status]');
        const submitButton = form.querySelector<HTMLButtonElement>('[data-submit-button]');

        if (!statusEl || !submitButton) {
          return;
        }

        submitButton.disabled = true;
        setStatus(statusEl, 'Sending message...', 'idle');

        try {
          const formData = new FormData(form);
          const actionClient = resolveActionClient(form.dataset.actionName ?? '');
          let data: unknown;
          let error: unknown;

          if (actionClient) {
            ({ data, error } = await actionClient(formData));
          } else {
            const response = await fetch(form.action, {
              method: 'POST',
              body: formData,
              headers: {
                Accept: 'application/json'
              }
            });
            const payload = await response.json().catch(() => null);
            data = payload;
            error = !response.ok || !payload?.ok ? payload ?? new Error('Request failed') : undefined;
          }

          if (error) {
            let message = 'Something went wrong. Please try again.';

            if (isInputError(error)) {
              const fieldErrors = Object.values(error.fields)
                .flat()
                .filter((value): value is string => Boolean(value));
              message = fieldErrors[0] ?? error.message ?? message;
            } else if (isActionError(error)) {
              message = error.message || message;
            }

            setStatus(statusEl, message, 'error');
            return;
          }

          const formName = form.dataset.actionName || form.getAttribute('aria-label') || 'form';
          trackUmamiEvent('form-submit', { form: formName });
          const responseMessage =
            typeof data === 'object' && data && 'message' in data && typeof data.message === 'string'
              ? data.message
              : 'Thanks, your message has been sent.';
          setStatus(statusEl, responseMessage, 'success');
          form.reset();
          setLoadedAt(form);

          if (window.turnstile && typeof window.turnstile.reset === 'function') {
            window.turnstile.reset();
          }
        } catch {
          setStatus(statusEl, 'Something went wrong. Please try again.', 'error');
        } finally {
          submitButton.disabled = false;
        }
      });
    }
  })();
</script>
