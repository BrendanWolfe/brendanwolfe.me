---
import TurnstileWidget from './TurnstileWidget.astro';

interface Props {
  action: string;
  ariaLabel?: string;
  submitLabel?: string;
  turnstileAction?: string;
  withTurnstile?: boolean;
}

const {
  action,
  ariaLabel = 'Form',
  submitLabel = 'Send Message',
  turnstileAction = 'contact_form',
  withTurnstile = true
} = Astro.props;
---

<form aria-label={ariaLabel} class="w-full text-left" method="POST" action={action} data-base-form>
  <div class="grid gap-3">
    <div class="absolute -left-[10000px] top-auto h-px w-px overflow-hidden" aria-hidden="true">
      <label>
        Company
        <input type="text" name="company" tabindex="-1" autocomplete="off" />
      </label>
    </div>

    <input type="hidden" name="formLoadedAt" data-form-loaded-at />

    <slot />

    {withTurnstile && (
      <TurnstileWidget action={turnstileAction} server:defer>
        <p slot="fallback" class="text-xs text-bw-body">Loading captcha challenge...</p>
      </TurnstileWidget>
    )}

    <p data-form-status class="min-h-5 text-sm text-bw-sub" role="status" aria-live="polite"></p>

    <button
      type="submit"
      class="mt-1 w-fit rounded-md bg-bw-accent px-4 py-2 text-base font-semibold text-bw-bg transition hover:bg-bw-accent-hover disabled:cursor-not-allowed disabled:opacity-60"
      data-submit-button
    >
      {submitLabel}
    </button>
  </div>
</form>

<script is:inline>
  (() => {
    const forms = document.querySelectorAll('form[data-base-form]');
    const trackUmamiEvent = (eventName, eventData) => {
      if (window.umami && typeof window.umami.track === 'function') {
        window.umami.track(eventName, eventData);
      }
    };

    const setLoadedAt = (form) => {
      const loadedAtInput = form.querySelector('[data-form-loaded-at]');
      if (loadedAtInput && !loadedAtInput.value) {
        loadedAtInput.value = String(Date.now());
      }
    };

    const setStatus = (statusEl, message, state) => {
      statusEl.textContent = message;
      statusEl.classList.remove('text-bw-sub', 'text-red-300', 'text-green-300');

      if (state === 'error') {
        statusEl.classList.add('text-red-300');
        return;
      }

      if (state === 'success') {
        statusEl.classList.add('text-green-300');
        return;
      }

      statusEl.classList.add('text-bw-sub');
    };

    for (const form of forms) {
      if (form.dataset.formReady === 'true') {
        continue;
      }

      form.dataset.formReady = 'true';
      setLoadedAt(form);

      form.addEventListener('submit', async (event) => {
        event.preventDefault();

        const statusEl = form.querySelector('[data-form-status]');
        const submitButton = form.querySelector('[data-submit-button]');

        if (!statusEl || !submitButton) {
          return;
        }

        submitButton.disabled = true;
        setStatus(statusEl, 'Sending message...', 'idle');

        try {
          const formData = new FormData(form);
          const response = await fetch(form.action, {
            method: 'POST',
            body: formData,
            headers: {
              Accept: 'application/json'
            }
          });

          const payload = await response.json().catch(() => null);
          const message = payload?.message ?? 'Something went wrong. Please try again.';

          if (!response.ok || !payload?.ok) {
            setStatus(statusEl, message, 'error');
            return;
          }

          trackUmamiEvent('contact-form-submit', { form: 'contact' });
          setStatus(statusEl, message, 'success');
          form.reset();
          setLoadedAt(form);

          if (window.turnstile && typeof window.turnstile.reset === 'function') {
            window.turnstile.reset();
          }
        } catch {
          setStatus(statusEl, 'Something went wrong. Please try again.', 'error');
        } finally {
          submitButton.disabled = false;
        }
      });
    }
  })();
</script>
