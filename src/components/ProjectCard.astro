---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import ButtonLink from './ui/ButtonLink.astro';

interface Props {
  title: string;
  description: string;
  image: ImageMetadata;
  tags: string[];
  liveUrl: string | null;
  githubUrl: string | null;
  priority?: boolean;
}

const { title, description, image, tags, liveUrl, githubUrl, priority = false } = Astro.props;
---

<article data-project-card class="flex h-full flex-col rounded-2xl border border-bw-border bg-bw-surface">
  <Image
    src={image}
    alt={`Preview of ${title}`}
    format="webp"
    widths={[336, 480, 672]}
    sizes="(min-width: 1024px) 336px, (min-width: 768px) calc(50vw - 2rem), calc(100vw - 2rem)"
    priority={priority}
    class="h-40 w-full shrink-0 rounded-t-lg border-b border-bw-border object-cover"
  />
  <div class="flex h-full flex-col px-5 pt-5 pb-5">
    <h3 class="text-xl font-semibold text-bw-heading">{title}</h3>
  <p class="mt-3 text-bw-body">{description}</p>
  <ul class="mt-4 mb-6 flex flex-wrap gap-2">
    {tags.map((tag) => (
      <li class="rounded-full border border-bw-border bg-bw-skill-bg px-2.5 py-1 text-sm text-bw-skill-text">{tag}</li>
    ))}
  </ul>
  <div class="flex gap-3 mt-auto">
    { liveUrl && (
      <ButtonLink
        href={liveUrl}
        variant="primary"
        size="compact"
        umamiEvent="project-live-demo-click"
        umamiEventData={{ project: title }}
      >
        Live Demo
      </ButtonLink>
    )}

    { githubUrl && (
      <ButtonLink
        href={githubUrl}
        variant="outline"
        size="compact"
        umamiEvent="project-github-click"
        umamiEventData={{ project: title }}
      >
        GitHub
      </ButtonLink>
    )}
  </div>
  </div>
</article>
