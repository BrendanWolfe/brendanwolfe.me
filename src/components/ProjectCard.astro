---
interface Props {
  title: string;
  description: string;
  image?: string;
  tags: string[];
  liveUrl: string;
  githubUrl: string;
}

const { title, description, image, tags, liveUrl, githubUrl } = Astro.props;
---

<article data-project-card class="flex h-full flex-col rounded-2xl border border-bw-border bg-bw-surface p-5">
  {image && (
    <img
      src={image}
      alt={`Preview of ${title}`}
      loading="lazy"
      class="mb-4 h-40 w-full rounded-lg border border-bw-border object-cover"
    />
  )}
  <h3 class="text-xl font-semibold text-bw-heading">{title}</h3>
  <p class="mt-3 text-bw-body">{description}</p>
  <ul class="mt-4 flex flex-wrap gap-2">
    {tags.map((tag) => (
      <li class="rounded-full border border-bw-border bg-bw-skill-bg px-2.5 py-1 text-sm text-bw-skill-text">{tag}</li>
    ))}
  </ul>
  <div class="mt-6 flex gap-3">
    <a href={liveUrl} target="_blank" rel="noreferrer" class="rounded-md bg-bw-accent px-3 py-2 text-base font-semibold text-bw-bg no-underline transition hover:bg-bw-accent-hover">Live Demo</a>
    <a href={githubUrl} target="_blank" rel="noreferrer" class="rounded-md border border-bw-border px-3 py-2 text-base font-semibold text-bw-heading no-underline transition hover:bg-bw-surface-hover">GitHub</a>
  </div>
</article>
