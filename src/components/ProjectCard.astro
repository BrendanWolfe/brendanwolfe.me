---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import ButtonLink from './ui/ButtonLink.astro';

interface Props {
  title: string;
  description: string;
  image: ImageMetadata;
  tags: string[];
  liveUrl: string | null;
  githubUrl: string | null;
}

const { title, description, image, tags, liveUrl, githubUrl } = Astro.props;
---

<article data-project-card class="flex h-full flex-col rounded-2xl border border-bw-border bg-bw-surface p-5">
  <Image
    src={image}
    alt={`Preview of ${title}`}
    width={720}
    format="webp"
    densities={[1.5, 2]}
    loading="lazy"
    class="mb-4 h-40 w-full rounded-lg border border-bw-border object-cover"
  />
  <h3 class="text-xl font-semibold text-bw-heading">{title}</h3>
  <p class="mt-3 text-bw-body">{description}</p>
  <ul class="mt-4 mb-6 flex flex-wrap gap-2">
    {tags.map((tag) => (
      <li class="rounded-full border border-bw-border bg-bw-skill-bg px-2.5 py-1 text-sm text-bw-skill-text">{tag}</li>
    ))}
  </ul>
  <div class="flex gap-3 mt-auto">
    { liveUrl && (
      <ButtonLink href={liveUrl} variant="primary" size="compact">Live Demo</ButtonLink>
    )}

    { githubUrl && (
      <ButtonLink
        href={githubUrl}
        variant="outline"
        size="compact"
        umamiEvent="github-link-click"
        umamiEventData={{ location: 'project-card', project: title }}
      >
        GitHub
      </ButtonLink>
    )}
  </div>
</article>
