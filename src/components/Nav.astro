---
import { getNavItems } from '../lib/content';
import ExternalLink from './ui/ExternalLink.astro';
import GitHubLink from './GitHubLink.astro';
import Icon from './Icon.astro';

interface NavItem {
  order: number;
  href: string;
  label: string;
  external?: boolean;
}

interface Props {
  navBrandText: string;
  githubUrl: string;
}

const items = (await getNavItems()) as NavItem[];
const { navBrandText, githubUrl } = Astro.props as Props;
const textLinkClass = 'font-sans text-base font-bold text-bw-sub no-underline transition-colors hover:text-bw-heading focus-visible:text-bw-heading';
---

<header class="sticky top-0 z-40 border-b border-bw-border/90 bg-bw-surface/85 backdrop-blur">
  <div class="mx-auto flex min-h-17 w-full max-w-6xl items-center justify-between gap-4 px-4 sm:px-6 lg:px-8 max-[40rem]:min-h-[4.4rem] max-[40rem]:py-2.5">
    <a class="font-sans text-[1.2rem] font-extrabold tracking-[0.03em] text-bw-heading no-underline" href="/">{navBrandText}</a>
    <button
      id="mobile-menu-trigger"
      type="button"
      class="inline-flex h-11 w-11 items-center justify-center rounded-md cursor-pointer border border-bw-border text-bw-heading transition-colors hover:border-bw-accent hover:text-bw-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-bw-accent min-[40.0625rem]:hidden"
      aria-label="Open menu"
      aria-controls="mobile-menu-overlay"
      aria-expanded="false"
    >
      <span class="sr-only">Open menu</span>
      <Icon name="menu" class="h-6 w-6" />
    </button>
    <nav aria-label="Primary navigation" class="max-[40rem]:hidden">
      <ul class="m-0 flex list-none items-center gap-4 p-0">
        {items.map((item) => {
          const isExternal = item.external ?? /^https?:\/\//.test(item.href);

          return (
            <li>
              {isExternal ? (
                <ExternalLink class={textLinkClass} href={item.href}>
                  {item.label}
                </ExternalLink>
              ) : (
                <a class={textLinkClass} href={item.href}>
                  {item.label}
                </a>
              )}
            </li>
          );
        })}
        <li>
          <GitHubLink href={githubUrl} mode="icon" umamiLocation="nav-desktop" />
        </li>
      </ul>
    </nav>
  </div>
</header>

<div
  id="mobile-menu-overlay"
  class="pointer-events-none fixed inset-0 z-50 bg-bw-bg/92 px-6 pb-8 pt-6 opacity-0 backdrop-blur transition-opacity duration-250 min-[40.0625rem]:hidden"
  aria-hidden="true"
  hidden
>
  <div class="flex min-h-full w-full flex-col">
    <div class="flex items-start justify-between gap-4">
      <a
        class="inline-flex h-12 w-12 items-center justify-center no-underline opacity-30 transition-opacity duration-200 hover:opacity-100 focus-visible:opacity-100 focus-visible:outline-none"
        href="/"
      >
        <span class="sr-only">Home</span>
        <img
          src="/apple-touch-icon.png"
          alt=""
          class="h-11 w-11 object-contain"
          loading="eager"
          decoding="async"
        />
      </a>
      <button
        id="mobile-menu-close"
        type="button"
        class="inline-flex h-11 w-11 items-center justify-center rounded-md cursor-pointer border border-bw-border text-bw-heading transition-colors hover:border-bw-accent hover:text-bw-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-bw-accent"
        aria-label="Close menu"
      >
        <span class="sr-only">Close menu</span>
        <Icon name="close" class="h-6 w-6" />
      </button>
    </div>
    <nav aria-label="Mobile navigation" class="flex flex-1 items-center justify-center">
      <ul class="m-0 flex list-none flex-col items-center gap-8 p-0 text-center">
        {items.map((item) => {
          const isExternal = item.external ?? /^https?:\/\//.test(item.href);

          return (
            <li>
              {isExternal ? (
                <ExternalLink
                  class="mobile-nav-link font-sans text-[clamp(2.5rem,9vw,3.5rem)] leading-[0.98] font-extrabold tracking-[-0.035em] text-bw-heading no-underline transition-colors hover:text-bw-accent focus-visible:text-bw-accent"
                  href={item.href}
                >
                  {item.label}
                </ExternalLink>
              ) : (
                <a
                  class="mobile-nav-link font-sans text-[clamp(2.5rem,9vw,3.5rem)] leading-[0.98] font-extrabold tracking-[-0.035em] text-bw-heading no-underline transition-colors hover:text-bw-accent focus-visible:text-bw-accent"
                  href={item.href}
                >
                  {item.label}
                </a>
              )}
            </li>
          );
        })}
        <li>
          <ExternalLink
            class="mobile-nav-link font-sans text-[clamp(2.5rem,9vw,3.5rem)] leading-[0.98] font-extrabold tracking-[-0.035em] text-bw-heading no-underline transition-colors hover:text-bw-accent focus-visible:text-bw-accent"
            href={githubUrl}
            umamiEvent="github-link-click"
            umamiEventData={{ location: 'nav-mobile' }}
          >
            GitHub
          </ExternalLink>
        </li>
      </ul>
    </nav>
  </div>
</div>

<script is:inline>
  (() => {
    const menuButton = document.querySelector('#mobile-menu-trigger');
    const overlay = document.querySelector('#mobile-menu-overlay');
    const closeButton = document.querySelector('#mobile-menu-close');
    const mobileLinks = overlay?.querySelectorAll('.mobile-nav-link');

    if (!(menuButton instanceof HTMLButtonElement) || !(overlay instanceof HTMLDivElement)) {
      return;
    }

    const closeMenu = () => {
      overlay.setAttribute('hidden', '');
      overlay.classList.add('opacity-0', 'pointer-events-none');
      overlay.setAttribute('aria-hidden', 'true');
      menuButton.setAttribute('aria-expanded', 'false');
      document.body.classList.remove('overflow-hidden');
    };

    const openMenu = () => {
      overlay.removeAttribute('hidden');
      overlay.classList.remove('opacity-0', 'pointer-events-none');
      overlay.setAttribute('aria-hidden', 'false');
      menuButton.setAttribute('aria-expanded', 'true');
      document.body.classList.add('overflow-hidden');
    };

    menuButton.addEventListener('click', () => {
      const isOpen = menuButton.getAttribute('aria-expanded') === 'true';
      if (isOpen) {
        closeMenu();
        return;
      }

      openMenu();
    });

    closeButton?.addEventListener('click', closeMenu);

    overlay.addEventListener('click', (event) => {
      if (event.target === overlay) {
        closeMenu();
      }
    });

    mobileLinks?.forEach((link) => {
      link.addEventListener('click', closeMenu);
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && menuButton.getAttribute('aria-expanded') === 'true') {
        closeMenu();
      }
    });
  })();
</script>
