---
import { getNavItems } from '../lib/content';
import ExternalLink from './ui/ExternalLink.astro';
import GitHubLink from './GitHubLink.astro';

interface NavItem {
  order: number;
  href: string;
  label: string;
  external?: boolean;
}

interface Props {
  navBrandText: string;
  githubUrl: string;
}

const items = (await getNavItems()) as NavItem[];
const { navBrandText, githubUrl } = Astro.props as Props;
const textLinkClass = 'font-sans text-base font-bold text-bw-sub no-underline transition-colors hover:text-bw-heading focus-visible:text-bw-heading';
---

<header class="sticky top-0 z-40 border-b border-bw-border/90 bg-bw-surface/85 backdrop-blur">
  <div class="mx-auto flex min-h-17 w-full max-w-6xl items-center justify-between gap-4 px-4 sm:px-6 lg:px-8 max-[40rem]:min-h-[4.4rem] max-[40rem]:flex-wrap max-[40rem]:justify-center max-[40rem]:py-2.5">
    <a class="font-sans text-[1.2rem] font-extrabold tracking-[0.03em] text-bw-heading no-underline max-[40rem]:w-full max-[40rem]:text-center" href="/">{navBrandText}</a>
    <nav aria-label="Primary navigation" class="max-[40rem]:w-full">
      <ul class="m-0 flex list-none items-center gap-4 p-0 max-[40rem]:w-full max-[40rem]:flex-wrap max-[40rem]:justify-center">
        {items.map((item) => (
          <li>
            <ExternalLink class={textLinkClass} href={item.href} external={item.external}>
              {item.label}
            </ExternalLink>
          </li>
        ))}
        <li>
          <GitHubLink href={githubUrl} mode="icon" />
        </li>
      </ul>
    </nav>
  </div>
</header>
