---
import Section from '../sections/Section.astro';
import SectionHeading from '../sections/SectionHeading.astro';
---

<Section id="about" labelledBy="about-heading" class="py-6">
  <SectionHeading id="about-heading">About</SectionHeading>

  <p class="mt-5 max-w-4xl text-bw-body">
    I am a full-stack web developer who has worked across agencies and freelance projects, building custom solutions for small and large
    businesses. I have worked with tech stacks such as:
  </p>

  <div class="mt-8 grid gap-y-6 md:grid-cols-3 md:gap-x-8">
    <div class="space-y-2">
      <p class="font-header text-sm font-bold uppercase tracking-[0.13em] text-white">Frontend</p>
      <p class="text-bw-body">Astro, React, Vue, Tailwind CSS</p>
    </div>
    <div class="space-y-2">
      <p class="font-header text-sm font-bold uppercase tracking-[0.13em] text-white">Backend</p>
      <p class="text-bw-body">Laravel, PHP, WordPress, REST APIs, SQL</p>
    </div>
    <div class="space-y-2">
      <p class="font-header text-sm font-bold uppercase tracking-[0.13em] text-white">Delivery</p>
      <p class="text-bw-body">Git, Docker, CI/CD, Testing Workflows</p>
    </div>
  </div>
</Section>
