---
import ContactForm from '../ContactForm.vue';
import Section from '../sections/Section.astro';
import SectionHeading from '../sections/SectionHeading.astro';

interface Props {
  contactFormEndpoint: string;
  turnstileSiteKey: string;
}

const { contactFormEndpoint, turnstileSiteKey } = Astro.props as Props;
---

<Section id="contact" labelledBy="contact-heading" class="py-6">
  <div class="grid gap-6 md:grid-cols-2 md:items-start">
    <div>
      <SectionHeading id="contact-heading">Contact</SectionHeading>
      <p class="mt-3 text-bw-body">
        If you have a project, role, or collaboration idea, send a message and I will get back to you.
      </p>
      <p class="mt-3 text-base text-bw-sub">I usually reply within 1-2 business days.</p>
    </div>

    <ContactForm
      client:visible
      formspree-endpoint={contactFormEndpoint}
      turnstile-site-key={turnstileSiteKey}
    />
  </div>
</Section>
