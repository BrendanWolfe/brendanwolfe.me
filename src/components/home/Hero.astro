---
import ButtonLink from '../ui/ButtonLink.astro';

interface Props {
  resumeUrl: string;
}

const { resumeUrl } = Astro.props as Props;
---

<section class="pt-0 pb-4 md:pt-1 md:pb-4">
  <p class="text-base uppercase tracking-[0.2em] text-bw-sub">Brendan Wolfe</p>
  <h1 class="mt-3 font-hero text-4xl font-bold leading-tight text-bw-heading md:text-5xl">
    Web Developer
    <span class="block text-bw-accent">&amp; Full-Stack Problem Solver</span>
  </h1>
  <p class="mt-4 max-w-2xl text-lg text-bw-body">
    I deliver fast, accessible web products with clean code, clear architecture, and practical product sense.
  </p>
  <div class="mt-6 flex flex-wrap gap-3">
    <ButtonLink
      href={resumeUrl}
      variant="primary"
      umamiEvent="resume-download-click"
      umamiEventData={{ location: 'hero' }}
    >
      Download Resume
    </ButtonLink>
    <ButtonLink href="#contact" variant="secondary" external={false}>Contact Me</ButtonLink>
  </div>
</section>
