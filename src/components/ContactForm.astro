<form aria-label="Contact form" class="w-full text-left">
  <div class="grid gap-3">
    <label class="grid gap-1.5 text-base font-medium text-bw-heading">
      Name
      <input
        name="name"
        type="text"
        autocomplete="name"
        class="w-full rounded-md border border-bw-border bg-bw-surface/60 px-3 py-2 text-bw-heading outline-none transition-colors focus:border-bw-accent"
      />
    </label>

    <label class="grid gap-1.5 text-base font-medium text-bw-heading">
      Email
      <input
        name="email"
        type="email"
        autocomplete="email"
        class="w-full rounded-md border border-bw-border bg-bw-surface/60 px-3 py-2 text-bw-heading outline-none transition-colors focus:border-bw-accent"
      />
    </label>

    <label class="grid gap-1.5 text-base font-medium text-bw-heading">
      Message
      <textarea
        name="message"
        rows="4"
        class="w-full rounded-md border border-bw-border bg-bw-surface/60 px-3 py-2 text-bw-heading outline-none transition-colors focus:border-bw-accent"
      ></textarea>
    </label>

    <button type="submit" class="mt-1 w-fit rounded-md bg-bw-accent px-4 py-2 text-base font-semibold text-bw-bg transition hover:bg-bw-accent-hover">
      Send Message
    </button>
  </div>
</form>
