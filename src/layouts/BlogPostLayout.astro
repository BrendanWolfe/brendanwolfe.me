---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import Layout from './Layout.astro';
import { getSiteSettings } from '../lib/content';
import { getBlogImage } from '../lib/blog-images';
import { formatBlogDate } from '../lib/blog';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const siteSettings = await getSiteSettings();
const formattedPublishDate = formatBlogDate(post.data.publishDate);
const featuredImage = getBlogImage(post.id, post.data.image);
---

<Layout
  title={post.data.title}
  description={post.data.description}
  navBrandText={siteSettings.navBrandText}
  githubUrl={siteSettings.githubUrl}
>
  <div class="blog-hero relative -mx-4 -mt-[clamp(0.6rem,2vw,1.2rem)] sm:-mx-6 lg:-mx-8">
    <Image
      src={featuredImage}
      alt={`Featured image for ${post.data.title}`}
      width={1400}
      format="webp"
      class="absolute inset-0 h-full w-full object-cover"
    />
    <div class="absolute inset-0 bg-bw-surface/82" />

    <div class="relative z-10 flex flex-col items-center justify-center px-6 py-24 text-center [text-shadow:0_3px_7px_rgba(0,0,0,0.4)] sm:px-10 sm:py-32 md:py-40">
      <a
        href="/blog"
        class="mb-6 inline-flex w-fit items-center gap-2 font-sans text-sm font-bold text-bw-sub no-underline transition-colors hover:text-bw-heading focus-visible:text-bw-heading"
      >
        <span aria-hidden="true">&larr;</span>
        <span>Back to blog</span>
      </a>

      <div class="mb-4 flex flex-wrap items-center justify-center gap-3 text-sm">
        <span class="font-sans font-bold uppercase tracking-[0.08em] text-bw-muted">
          {post.data.category}
        </span>
        <span aria-hidden="true" class="text-bw-border">/</span>
        <time datetime={post.data.publishDate.toISOString()} class="text-bw-muted">
          {formattedPublishDate}
        </time>
      </div>

      <h1 class="max-w-3xl font-display text-4xl font-extrabold tracking-[-0.055em] text-bw-heading sm:text-5xl md:text-6xl">
        {post.data.title}
      </h1>
      <p class="mt-3 max-w-2xl text-base leading-relaxed text-bw-body sm:text-lg">
        {post.data.description}
      </p>
    </div>
  </div>

  <article class="mx-auto max-w-4xl">
    <div class="bw-prose mx-auto w-full max-w-3xl py-8 md:py-12">
      <slot />
    </div>
  </article>
</Layout>
