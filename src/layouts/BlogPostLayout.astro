---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import Layout from './Layout.astro';
import { getSiteSettings } from '../lib/content';
import { getBlogImage } from '../lib/blog-images';
import { formatBlogDate } from '../lib/blog';

interface Props {
  post: CollectionEntry<'blog'>;
  relatedPosts?: CollectionEntry<'blog'>[];
}

const { post, relatedPosts = [] } = Astro.props;
const siteSettings = await getSiteSettings();
const formattedPublishDate = formatBlogDate(post.data.publishDate);
const featuredImage = getBlogImage(post.data.image);
---

<Layout
  title={post.data.title}
  description={post.data.description}
  navBrandText={siteSettings.navBrandText}
  githubUrl={siteSettings.githubUrl}
>
  <div class="blog-hero relative -mx-4 -mt-[clamp(0.6rem,2vw,1.2rem)] sm:-mx-6 lg:-mx-8">
    <Image
      src={featuredImage}
      alt={`Featured image for ${post.data.title}`}
      width={1400}
      format="webp"
      class="absolute inset-0 h-full w-full object-cover"
    />
    <div class="absolute inset-0 bg-bw-surface/82" />

    <div class="relative z-10 flex flex-col items-center justify-center px-6 py-24 text-center [text-shadow:0_3px_7px_rgba(0,0,0,0.4)] sm:px-10 sm:py-32 md:py-40">
      <a
        href="/blog"
        class="mb-6 inline-flex w-fit items-center gap-2 font-sans text-sm font-bold text-bw-sub no-underline transition-colors hover:text-bw-heading focus-visible:text-bw-heading"
      >
        <span aria-hidden="true">&larr;</span>
        <span>Back to blog</span>
      </a>

      <div class="mb-4 text-sm">
        <time datetime={post.data.publishDate.toISOString()} class="text-bw-muted">
          {formattedPublishDate}
        </time>
      </div>

      <h1 class="max-w-3xl font-display text-4xl font-extrabold tracking-[-0.055em] text-bw-heading sm:text-5xl md:text-6xl">
        {post.data.title}
      </h1>
      <p class="mt-3 max-w-2xl text-base leading-relaxed text-bw-body sm:text-lg">
        {post.data.description}
      </p>
      <div class="mt-5 flex max-w-2xl flex-wrap justify-center gap-2">
        {post.data.tags.map((tag) => (
          <span class="rounded-full border border-bw-border/80 bg-black/20 px-3 py-1.5 font-sans text-[0.72rem] font-bold text-bw-heading">
            {tag}
          </span>
        ))}
      </div>
    </div>
  </div>

  <article class="mx-auto max-w-4xl">
    <div class="bw-prose mx-auto w-full max-w-3xl py-8 md:py-12">
      <slot />
    </div>
  </article>

  {
    relatedPosts.length > 0 && (
      <section class="mx-auto max-w-6xl border-t border-bw-border/80 py-8 md:py-10">
        <p class="font-sans text-xs font-bold uppercase tracking-[0.12em] text-bw-muted">Related posts</p>
        <div class="mt-4 grid gap-8 md:grid-cols-2 lg:gap-10 xl:grid-cols-3">
          {relatedPosts.map((relatedPost) => (
            <article class="group flex h-full flex-col overflow-hidden rounded-2xl border border-bw-border bg-bw-surface p-5 transition-transform duration-200 hover:-translate-y-1">
              <a href={`/blog/${relatedPost.id}/`} class="-mx-5 -mt-5 mb-5 block overflow-hidden">
                <Image
                  src={getBlogImage(relatedPost.data.image)}
                  alt={`Featured image for ${relatedPost.data.title}`}
                  width={960}
                  format="webp"
                  densities={[1.5, 2]}
                  class="h-52 w-full border-b border-bw-border object-cover"
                />
              </a>

              <div class="mb-4 text-sm">
                <time datetime={relatedPost.data.publishDate.toISOString()} class="text-bw-muted">
                  {formatBlogDate(relatedPost.data.publishDate)}
                </time>
              </div>

              <div class="flex flex-1 flex-col gap-3">
                <h2 class="font-display text-[1.7rem] font-extrabold leading-tight tracking-[-0.04em] text-bw-heading">
                  <a
                    href={`/blog/${relatedPost.id}/`}
                    class="no-underline transition-colors group-hover:text-bw-accent-hover focus-visible:text-bw-accent-hover"
                  >
                    {relatedPost.data.title}
                  </a>
                </h2>
                <div class="mt-2 flex flex-wrap gap-2">
                  {relatedPost.data.tags.map((tag) => (
                    <span class="rounded-full border border-bw-border/80 bg-black/10 px-2.5 py-1 font-sans text-[0.72rem] font-bold text-bw-muted">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>

              <div class="mt-6">
                <a
                  href={`/blog/${relatedPost.id}/`}
                  class="inline-flex items-center gap-2 font-sans text-sm font-bold text-bw-sub no-underline transition-colors hover:text-bw-heading focus-visible:text-bw-heading"
                >
                  <span>Read post</span>
                  <span aria-hidden="true">→</span>
                </a>
              </div>
            </article>
          ))}
        </div>
      </section>
    )
  }
</Layout>
