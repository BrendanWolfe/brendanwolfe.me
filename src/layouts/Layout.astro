---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { getSiteSettings } from '../lib/content';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  lang?: string;
  navBrandText?: string;
  githubUrl?: string;
}

const {
  title = 'Brendan Wolfe | Web Developer',
  description = 'Portfolio website for Brendan Wolfe',
  canonical,
  ogImage = '/og-image.png',
  noindex = false,
  lang = 'en',
  navBrandText: navBrandTextProp,
  githubUrl: githubUrlProp
} = Astro.props;

let navBrandText = navBrandTextProp;
let githubUrl = githubUrlProp;

if (!navBrandText || !githubUrl) {
  const siteSettings = await getSiteSettings();
  navBrandText = navBrandText ?? siteSettings.navBrandText;
  githubUrl = githubUrl ?? siteSettings.githubUrl;
}

const pageTitle = title.includes('Brendan Wolfe') ? title : `${title} | Brendan Wolfe`;
const canonicalUrl = canonical ?? Astro.url?.toString();
const ogImageUrl = ogImage.startsWith('http') ? ogImage : new URL(ogImage, Astro.url).toString();
const umamiScript = import.meta.env.UMAMI_SCRIPT;
const umamiWebsiteId = import.meta.env.UMAMI_WEBSITE_ID;
const hasUmami = Boolean(umamiScript && umamiWebsiteId);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    {hasUmami && <script is:inline defer src={umamiScript} data-website-id={umamiWebsiteId}></script>}
    <title>{pageTitle}</title>
  </head>
  <body class="min-h-screen bg-[radial-gradient(circle_at_0%_0%,#1f2b3d_0%,#151a22_55%)] font-body leading-relaxed text-bw-body">
    <a
      class="absolute -left-2499.75 top-0 z-1000 rounded-md bg-bw-accent px-3.5 py-2.5 font-bold text-bw-bg no-underline focus-visible:left-4 focus-visible:top-4"
      href="#main-content"
    >
      Skip to main content
    </a>
    <div class="flex min-h-screen flex-col">
      <Nav navBrandText={navBrandText} githubUrl={githubUrl} />
      <main
        id="main-content"
        class="mx-auto w-full max-w-6xl flex-1 px-4 pb-[clamp(2rem,6vw,4rem)] pt-[clamp(0.6rem,2vw,1.2rem)] sm:px-6 lg:px-8"
      >
        <slot />
      </main>
      <button
        id="mobile-back-to-top"
        type="button"
        class="pointer-events-none fixed bottom-5 right-5 z-50 inline-flex h-11 w-11 items-center justify-center rounded-full border border-bw-border bg-bw-surface/90 text-bw-heading opacity-0 shadow-lg backdrop-blur transition-opacity duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-bw-accent"
        aria-label="Back to top"
        aria-hidden="true"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round">
          <path d="M12 19V5"></path>
          <path d="M6 11L12 5L18 11"></path>
        </svg>
      </button>
      <Footer githubUrl={githubUrl} />
    </div>
    <script is:inline>
      (() => {
        const button = document.querySelector('#mobile-back-to-top');
        if (!(button instanceof HTMLButtonElement)) {
          return;
        }

        const threshold = 320;
        const reducedMotionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');

        const updateVisibility = () => {
          const visible = window.scrollY > threshold;
          button.classList.toggle('opacity-0', !visible);
          button.classList.toggle('pointer-events-none', !visible);
          button.setAttribute('aria-hidden', visible ? 'false' : 'true');
        };

        button.addEventListener('click', () => {
          window.scrollTo({
            top: 0,
            behavior: reducedMotionQuery.matches ? 'auto' : 'smooth'
          });
        });

        window.addEventListener('scroll', updateVisibility, { passive: true });
        window.addEventListener('resize', updateVisibility);
        updateVisibility();
      })();
    </script>
  </body>
</html>
