---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  lang?: string;
}

const {
  title = 'Brendan Wolfe | Web Developer',
  description = 'Portfolio website for Brendan Wolfe',
  canonical,
  ogImage = '/og-image.png',
  noindex = false,
  lang = 'en',
} = Astro.props;

const pageTitle = title.includes('Brendan Wolfe') ? title : `${title} | Brendan Wolfe`;
const canonicalUrl = canonical ?? Astro.url?.toString();
const ogImageUrl = ogImage.startsWith('http') ? ogImage : new URL(ogImage, Astro.url).toString();
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=Manrope:wght@500;700;800&display=swap"
    />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <title>{pageTitle}</title>
  </head>
  <body class="min-h-screen bg-[radial-gradient(circle_at_0%_0%,#1f2b3d_0%,#151a22_55%)] font-sans leading-relaxed text-bw-body">
    <a
      class="absolute -left-[9999px] top-0 z-[1000] rounded-md bg-bw-accent px-3.5 py-2.5 font-bold text-bw-bg no-underline focus-visible:left-4 focus-visible:top-4"
      href="#main-content"
    >
      Skip to main content
    </a>
    <div class="flex min-h-screen flex-col">
      <Nav />
      <main
        id="main-content"
        class="mx-auto w-full max-w-[72rem] flex-1 px-4 pb-[clamp(2rem,6vw,4rem)] pt-[clamp(0.6rem,2vw,1.2rem)] sm:px-6 lg:px-8"
      >
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
