---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import { formatBlogDate, getBlogTags } from '../lib/blog';
import { getBlogPosts, getSiteSettings } from '../lib/content';

const siteSettings = await getSiteSettings();
const posts = await getBlogPosts();
const tags = getBlogTags(posts);
const pageDescription = 'Useful notes, small tutorials, and the occasional write-up from whatever I am working on.';
---

<Layout
  title="Blog"
  description={pageDescription}
  navBrandText={siteSettings.navBrandText}
  githubUrl={siteSettings.githubUrl}
>
  <div class="flex flex-col gap-10 py-10 md:gap-14 md:py-14">
    <section class="flex flex-col gap-4 pt-2">
      <h1 class="max-w-3xl font-display text-5xl font-extrabold tracking-[-0.055em] text-bw-accent sm:text-6xl">
        Blog
      </h1>
      <p class="max-w-3xl text-lg leading-relaxed text-bw-body">
        Useful notes, small tutorials, and the occasional write-up from whatever I am working on.
      </p>
    </section>

    <section class="flex flex-col gap-6">
      <div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
        <div class="flex flex-col gap-2.5">
          <p class="font-sans text-[0.68rem] font-bold uppercase tracking-[0.22em] text-bw-muted">
            Tags
          </p>
          <div id="blog-tag-filter" class="w-full">
            <div class="relative w-[11rem] max-w-full">
              <button
                id="blog-tag-trigger"
                type="button"
                aria-expanded="false"
                aria-controls="blog-tag-menu"
                class="inline-flex w-full items-center justify-between gap-5 rounded-2xl border border-bw-border bg-transparent px-4 py-3 text-left font-sans text-sm font-bold text-bw-heading transition-colors hover:border-bw-heading focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-bw-accent"
              >
                <span>Add tags</span>
                <span
                  id="blog-tag-trigger-caret"
                  aria-hidden="true"
                  class="text-sm leading-none text-bw-muted transition-transform duration-200"
                >
                  ▾
                </span>
              </button>

              <div
                id="blog-tag-menu"
                class="absolute left-0 top-full z-20 mt-2 hidden w-[200%] max-w-[56rem] min-w-full overflow-hidden rounded-2xl border border-bw-border bg-bw-surface shadow-[0_16px_40px_rgba(0,0,0,0.28)]"
              >
                <div class="max-h-72 overflow-y-auto p-2">
                  {tags.map((tag) => (
                    <button
                      type="button"
                      data-blog-tag-option={tag}
                      aria-pressed="false"
                      class="blog-tag-option flex w-full items-center justify-between rounded-xl px-3 py-2 text-left font-sans text-sm font-bold text-bw-muted transition-colors hover:bg-black/10 hover:text-bw-heading focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-bw-accent"
                    >
                      <span>{tag}</span>
                      <span aria-hidden="true" class="text-base leading-none opacity-0 transition-opacity">+</span>
                    </button>
                  ))}
                </div>
              </div>
            </div>

            <div class="mt-3 flex max-w-4xl flex-wrap items-center gap-3">
              <div id="blog-selected-tags" class="flex flex-wrap gap-2"></div>
              <button
                id="blog-clear-tags"
                type="button"
                class="hidden font-sans text-xs font-bold text-bw-sub underline decoration-bw-border/70 underline-offset-4 transition-colors hover:text-bw-heading focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-bw-accent"
              >
                Clear all
              </button>
            </div>
            <p id="blog-selected-tags-empty" class="mt-1 text-sm text-bw-muted">Showing all posts.</p>
          </div>
        </div>

        <label class="flex w-full max-w-48 flex-col gap-2">
          <span class="font-sans text-[0.68rem] font-bold uppercase tracking-[0.22em] text-bw-muted">Sort</span>
          <select
            id="blog-sort"
            class="cursor-pointer border-0 border-b border-bw-border bg-transparent px-0 py-2 font-sans text-sm font-bold text-bw-heading focus-visible:outline-none focus-visible:ring-0"
          >
            <option value="newest">Newest first</option>
            <option value="oldest">Oldest first</option>
          </select>
        </label>
      </div>

      {posts.length > 0 ? (
        <>
          <div id="blog-post-grid" class="grid gap-8 md:grid-cols-2 lg:gap-10">
            {posts.map((post) => (
              <article
                data-blog-card
                data-tags={post.data.tags.join('|')}
                data-publish-date={post.data.publishDate.toISOString()}
                class="group flex h-full flex-col overflow-hidden rounded-2xl border border-bw-border bg-bw-surface p-5 transition-transform duration-200 hover:-translate-y-1"
              >
                <a href={`/blog/${post.id}/`} class="-mx-5 -mt-5 mb-5 block overflow-hidden">
                  <Image
                    src={post.data.image}
                    alt={`Featured image for ${post.data.title}`}
                    width={960}
                    format="webp"
                    densities={[1.5, 2]}
                    class="h-52 w-full border-b border-bw-border object-cover"
                  />
                </a>

                <div class="mb-4 text-sm">
                  <time datetime={post.data.publishDate.toISOString()} class="text-bw-muted">
                    {formatBlogDate(post.data.publishDate)}
                  </time>
                </div>

                <div class="flex flex-1 flex-col gap-3">
                  <h2 class="font-display text-[1.7rem] font-extrabold leading-tight tracking-[-0.04em] text-bw-heading">
                    <a
                      href={`/blog/${post.id}/`}
                      class="no-underline transition-colors group-hover:text-bw-accent-hover focus-visible:text-bw-accent-hover"
                    >
                      {post.data.title}
                    </a>
                  </h2>
                  <p class="text-bw-body">{post.data.description}</p>
                  <div class="mt-2 flex flex-wrap gap-2">
                    {post.data.tags.map((tag) => (
                      <span class="rounded-full border border-bw-border/80 bg-black/10 px-2.5 py-1 font-sans text-[0.72rem] font-bold text-bw-muted">
                        {tag}
                      </span>
                    ))}
                  </div>
                </div>

                <div class="mt-6">
                  <a
                    href={`/blog/${post.id}/`}
                    class="inline-flex items-center gap-2 font-sans text-sm font-bold text-bw-sub no-underline transition-colors hover:text-bw-heading focus-visible:text-bw-heading"
                  >
                    <span>Read post</span>
                    <span aria-hidden="true">→</span>
                  </a>
                </div>
              </article>
            ))}
          </div>

          <div id="blog-empty-state" class="hidden py-6" aria-live="polite">
            <p class="font-sans text-base font-bold text-bw-heading">No posts match those tags yet.</p>
            <p class="mt-2 text-sm text-bw-muted">Try removing a tag or switch the sort order.</p>
          </div>
        </>
      ) : (
        <div class="py-6">
          <p class="font-sans text-base font-bold text-bw-heading">No posts yet.</p>
          <p class="mt-2 text-sm text-bw-muted">The page is ready. It just needs the first entry.</p>
        </div>
      )}
    </section>
  </div>
</Layout>

<script is:inline>
  (() => {
    const filterContainer = document.querySelector('#blog-tag-filter');
    const trigger = document.querySelector('#blog-tag-trigger');
    const caret = document.querySelector('#blog-tag-trigger-caret');
    const menu = document.querySelector('#blog-tag-menu');
    const selectedTagsContainer = document.querySelector('#blog-selected-tags');
    const clearTagsButton = document.querySelector('#blog-clear-tags');
    const selectedTagsEmptyState = document.querySelector('#blog-selected-tags-empty');
    const sortSelect = document.querySelector('#blog-sort');
    const grid = document.querySelector('#blog-post-grid');
    const emptyState = document.querySelector('#blog-empty-state');

    if (
      !(filterContainer instanceof HTMLDivElement) ||
      !(trigger instanceof HTMLButtonElement) ||
      !(caret instanceof HTMLSpanElement) ||
      !(menu instanceof HTMLDivElement) ||
      !(selectedTagsContainer instanceof HTMLDivElement) ||
      !(clearTagsButton instanceof HTMLButtonElement) ||
      !(selectedTagsEmptyState instanceof HTMLParagraphElement) ||
      !(sortSelect instanceof HTMLSelectElement) ||
      !(grid instanceof HTMLDivElement) ||
      !(emptyState instanceof HTMLDivElement)
    ) {
      return;
    }

    const buttons = [...filterContainer.querySelectorAll('[data-blog-tag-option]')].filter(
      (button) => button instanceof HTMLButtonElement,
    );
    const cards = [...grid.querySelectorAll('[data-blog-card]')].filter(
      (card) => card instanceof HTMLElement,
    );

    if (buttons.length === 0 || cards.length === 0) {
      return;
    }

    const activeTags = new Set();
    let isMenuOpen = false;

    const setMenuState = (nextOpen) => {
      isMenuOpen = nextOpen;
      menu.classList.toggle('hidden', !isMenuOpen);
      trigger.setAttribute('aria-expanded', isMenuOpen ? 'true' : 'false');
      caret.classList.toggle('rotate-180', isMenuOpen);
    };

    const setButtonState = () => {
      buttons.forEach((button) => {
        const tag = button.dataset.blogTagOption ?? '';
        const isActive = activeTags.has(tag);
        const icon = button.querySelector('span:last-child');
        button.setAttribute('aria-pressed', isActive ? 'true' : 'false');
        button.classList.toggle('bg-black/10', isActive);
        button.classList.toggle('text-bw-heading', isActive);
        button.classList.toggle('text-bw-muted', !isActive);
        if (icon instanceof HTMLSpanElement) {
          icon.textContent = isActive ? '✓' : '+';
          icon.classList.toggle('opacity-100', isActive);
          icon.classList.toggle('opacity-0', !isActive);
        }
      });
    };

    const renderSelectedTags = () => {
      selectedTagsContainer.innerHTML = '';

      if (activeTags.size === 0) {
        selectedTagsEmptyState.classList.remove('hidden');
        clearTagsButton.classList.add('hidden');
        trigger.firstElementChild && (trigger.firstElementChild.textContent = 'Add tags');
        return;
      }

      selectedTagsEmptyState.classList.add('hidden');
      clearTagsButton.classList.remove('hidden');
      trigger.firstElementChild && (trigger.firstElementChild.textContent = 'Add more tags');

      [...activeTags]
        .sort((left, right) => left.localeCompare(right))
        .forEach((tag) => {
          const pill = document.createElement('button');
          pill.type = 'button';
          pill.dataset.selectedTag = tag;
          pill.className =
            'inline-flex items-center gap-2 rounded-full border border-bw-border bg-black/10 px-3 py-1.5 font-sans text-xs font-bold text-bw-heading transition-colors hover:border-bw-heading focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-bw-accent';
          pill.innerHTML = `<span>${tag}</span><span aria-hidden="true" class="text-sm leading-none">×</span>`;
          selectedTagsContainer.append(pill);
        });
    };

    const applyFilters = () => {
      const sortedCards = [...cards].sort((left, right) => {
        const leftDate = Date.parse(left.dataset.publishDate ?? '');
        const rightDate = Date.parse(right.dataset.publishDate ?? '');
        return sortSelect.value === 'oldest' ? leftDate - rightDate : rightDate - leftDate;
      });

      sortedCards.forEach((card) => {
        const cardTags = (card.dataset.tags ?? '').split('|').filter(Boolean);
        const matchesTags =
          activeTags.size === 0 || [...activeTags].every((tag) => cardTags.includes(tag));
        card.hidden = !matchesTags;
        grid.append(card);
      });

      emptyState.classList.toggle('hidden', sortedCards.some((card) => !card.hidden));
    };

    const syncUi = () => {
      setButtonState();
      renderSelectedTags();
      applyFilters();
    };

    trigger.addEventListener('click', () => {
      setMenuState(!isMenuOpen);
    });

    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        const tag = button.dataset.blogTagOption ?? '';

        if (!tag) {
          return;
        }

        if (activeTags.has(tag)) {
          activeTags.delete(tag);
        } else {
          activeTags.add(tag);
        }

        syncUi();
      });
    });

    selectedTagsContainer.addEventListener('click', (event) => {
      const target = event.target;

      if (!(target instanceof HTMLElement)) {
        return;
      }

      const button = target.closest('[data-selected-tag]');

      if (!(button instanceof HTMLButtonElement)) {
        return;
      }

      const tag = button.dataset.selectedTag ?? '';

      if (!tag) {
        return;
      }

      activeTags.delete(tag);
      syncUi();
    });

    clearTagsButton.addEventListener('click', () => {
      activeTags.clear();
      syncUi();
    });

    sortSelect.addEventListener('change', applyFilters);

    document.addEventListener('click', (event) => {
      const target = event.target;

      if (!(target instanceof Node) || filterContainer.contains(target)) {
        return;
      }

      setMenuState(false);
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        setMenuState(false);
      }
    });

    syncUi();
  })();
</script>
