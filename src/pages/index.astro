---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/home/Hero.astro';
// import Projects from '../components/home/Projects.astro';
import About from '../components/home/About.astro';
import HomeContact from '../components/home/HomeContact.astro';
import { getSiteSettings } from '../lib/content';

const siteSettings = await getSiteSettings();
---

<Layout
  title="Brendan Wolfe | Web Developer"
  description="Portfolio of Brendan Wolfe, web developer and problem solver."
  navBrandText={siteSettings.navBrandText}
  githubUrl={siteSettings.githubUrl}
>
  <div class="space-y-8 py-8 md:space-y-12 md:py-10">
    <Hero resumeUrl={siteSettings.resumeUrl} />
    <!-- <Projects /> -->
    <About />
    <HomeContact
      contactFormEndpoint={siteSettings.contactFormEndpoint}
      turnstileSiteKey={siteSettings.turnstileSiteKey}
    />
  </div>
</Layout>
